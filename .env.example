# Copy to .env and set your MongoDB connection string
DATABASE_URL="mongodb://localhost:27017/mydelivery"

# JWT settings
JWT_SECRET=changeme
JWT_ISSUER=mydelivery
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=30d

# Resend API key (get from https://resend.com)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM="MyDelivery <onboarding@example.com>"
